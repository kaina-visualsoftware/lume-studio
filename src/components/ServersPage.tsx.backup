type ServerStatus = 'online' | 'offline' | 'maintenance' | 'degraded';
type ServerType = 'vps' | 'dedicated' | 'cloud' | 'shared' | 'colocation';
type BillingCycle = 'monthly' | 'annually' | 'hourly';

interface ResourceUsage { used: number; total: number; }

interface AccessTerminal {
  id: string;
  label: string;
  ip: string;
  port: number;
  protocol: 'SSH' | 'RDP' | 'VNC' | 'HTTPS';
  lastAccess: Date;
  isActive: boolean;
}

interface Server {
  id: string;
  name: string;
  hostname: string;
  type: ServerType;
  status: ServerStatus;
  provider: string;
  region: string;
  ip: { public: string; private?: string; ipv6?: string };
  specs: { cpu: number; ram: number; storage: number; bandwidth: number };
  usage: { cpu: ResourceUsage; ram: ResourceUsage; storage: ResourceUsage; bandwidth: ResourceUsage; uptime: number };
  cost: { amount: number; cycle: BillingCycle; nextBilling: Date; annualTotal: number };
  terminals: AccessTerminal[];
  tags: string[];
  os: string;
  createdAt: Date;
  notes?: string;
}

interface HostingService {
  id: string;
  name: string;
  type: 'domain' | 'cdn' | 'email' | 'ssl' | 'storage' | 'database' | 'monitoring';
  provider: string;
  status: 'active' | 'expiring' | 'expired';
  cost: { amount: number; cycle: BillingCycle; nextBilling: Date };
}

